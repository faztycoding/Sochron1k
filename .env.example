# Price Data
TWELVE_DATA_API_KEY=your_twelve_data_key

# App Settings
APP_ENV=development
APP_SECRET_KEY=generate_a_random_secret
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
