# Database
DATABASE_URL=postgresql+asyncpg://sochron:your_password_here@localhost:5432/sochron1k
DB_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://localhost:6379/0

# AI APIs
GEMINI_API_KEY=your_gemini_api_key
